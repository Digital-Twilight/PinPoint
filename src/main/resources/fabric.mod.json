{
  "schemaVersion": 1,
  "id": "pinpoint",
  "version": "${version}",
  "name": "PinPoint",
  "description": "Adds /setwaypoint command for quick waypoint creation with automatic chat coordinate tracking and smart suggestions",
  "authors": [
    "Phantom"
  ],
  "contact": {
    "homepage": "https://www.curseforge.com/minecraft/mc-mods/pinpoint",
    "sources": "https://github.com/Digital-Twilight/PinPoint",
    "issues": "https://github.com/Digital-Twilight/PinPoint/issues"
  },
  "license": "GNU General Public License v3.0",
  "icon": "assets/pinpoint/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.phantom.pinpoint.client.PinPointClient"
    ],
    "main": [
      "io.phantom.pinpoint.PinPoint"
    ]
  },
  "mixins": [
    "pinpoint.mixins.json",
    {
      "config": "pinpoint.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "xaerominimap": ">=24.0.0"
  },
  "custom": {
    "modmenu": {
      "parent": "xaerominimap"
    }
  }
}
